---
---

<div class="bg-gradient-to-b from-gray-100 to-white pt-12 pb-8 overflow-hidden relative">
  <!-- Círculos decorativos de fondo -->
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-gray-200 rounded-full opacity-30 blur-3xl"></div>
  <div class="absolute top-1/2 -left-24 w-64 h-64 bg-red-100 rounded-full opacity-40 blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Grid principal: Textos e Imagen -->
    <div class="flex flex-col lg:flex-row items-center justify-between mb-16">
      
      <!-- Columna Izquierda: Etiquetas y Botones -->
      <div class="w-full lg:w-5/12 flex flex-col items-center lg:items-start space-y-4 mb-10 lg:mb-0">
        
        <!-- Cintas (Ribbons) -->
        <div class="w-full relative shadow-md">
          <div class="bg-gray-800 text-white font-black text-xl md:text-2xl px-6 py-3 rounded-tr-xl transform -skew-x-12 inline-block">
            <span class="inline-block transform skew-x-12">Compra • Venta • Consignación</span>
          </div>
        </div>
        
        <div class="w-11/12 relative shadow-md mt-[-10px] z-10">
          <div class="bg-red-600 text-white font-black text-xl md:text-2xl px-6 py-3 rounded-bl-xl rounded-tr-xl transform -skew-x-12 inline-block ml-4 md:ml-8">
            <span class="inline-block transform skew-x-12">Permuta • Financiación</span>
          </div>
        </div>

        <!-- Botones de Acción -->
        <div class="mt-8 flex flex-col sm:flex-row gap-4 w-full md:w-auto ml-4 md:ml-8 pt-6">
          <a href="#catalogoGrid" onclick="document.getElementById('buscador').focus()" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all text-center flex items-center justify-center gap-2 text-lg border-b-4 border-red-800 active:border-b-0 active:translate-y-1">
            Ver vehículos disponibles
          </a>
          <a href="https://wa.me/573202832616?text=Hola,%20me%20interesan%20los%20veh%C3%ADculos%20disponibles" target="_blank" class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all flex justify-center items-center gap-2 text-lg border-b-4 border-green-800 active:border-b-0 active:translate-y-1">
            <i data-lucide="message-circle" class="w-6 h-6"></i>
            3202832616
          </a>
        </div>
      </div>

      <!-- Columna Derecha: Vehículo principal -->
      <div class="w-full lg:w-7/12 relative flex justify-center lg:justify-end">
        <!-- Puedes cambiar "toyota_fortuner.png" por otra imagen en formato png transparente en tu carpeta public -->
        <img src="/toyota_fortuner.png" alt="Toyota Fortuner" class="w-full max-w-2xl object-contain drop-shadow-2xl hover:scale-105 transition-transform duration-700 z-10" />
      </div>
    </div> <!-- Fin Grid Hero -->

    <!-- Separador y Mensaje Central -->
    <div class="text-center mb-10 pb-6 border-b border-gray-200">
      <h2 class="text-xl md:text-2xl font-medium text-gray-700">
        Tu aliado en <span class="font-extrabold text-gray-900">Toyota usados</span>, con respaldo y transparencia en cada negocio.
      </h2>
    </div>

    <!-- Fila de 5 Iconos de Servicios -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-6 text-center">
      <!-- Icono Compra -->
      <div class="flex flex-col items-center group cursor-default">
        <div class="w-16 h-16 bg-white border-2 border-gray-100 rounded-full flex items-center justify-center text-gray-700 group-hover:border-red-600 group-hover:text-red-600 group-hover:shadow-lg transition-all mb-3 relative overflow-hidden">
          <i data-lucide="car" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-110"></i>
        </div>
        <span class="font-bold text-gray-800">Compra</span>
      </div>

      <!-- Icono Venta -->
      <div class="flex flex-col items-center group cursor-default">
        <div class="w-16 h-16 bg-white border-2 border-gray-100 rounded-full flex items-center justify-center text-gray-700 group-hover:border-red-600 group-hover:text-red-600 group-hover:shadow-lg transition-all mb-3 relative overflow-hidden">
          <i data-lucide="badge-dollar-sign" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-110"></i>
        </div>
        <span class="font-bold text-gray-800">Venta</span>
      </div>

      <!-- Icono Consignación -->
      <div class="flex flex-col items-center group cursor-default">
        <div class="w-16 h-16 bg-white border-2 border-gray-100 rounded-full flex items-center justify-center text-gray-700 group-hover:border-red-600 group-hover:text-red-600 group-hover:shadow-lg transition-all mb-3 relative overflow-hidden">
          <i data-lucide="clipboard-list" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-110"></i>
        </div>
        <span class="font-bold text-gray-800">Consignación</span>
      </div>

      <!-- Icono Permuta -->
      <div class="flex flex-col items-center group cursor-default">
        <div class="w-16 h-16 bg-white border-2 border-gray-100 rounded-full flex items-center justify-center text-gray-700 group-hover:border-red-600 group-hover:text-red-600 group-hover:shadow-lg transition-all mb-3 relative overflow-hidden">
          <i data-lucide="refresh-ccw" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-110 text-red-600"></i> <!-- Según la imagen este es rojo -->
        </div>
        <span class="font-bold text-gray-800">Permuta</span>
      </div>

      <!-- Icono Financiación -->
      <div class="col-span-2 md:col-span-1 flex flex-col items-center group cursor-default">
        <div class="w-16 h-16 bg-white border-2 border-gray-100 rounded-full flex items-center justify-center text-gray-700 group-hover:border-red-600 group-hover:text-red-600 group-hover:shadow-lg transition-all mb-3 relative overflow-hidden">
          <i data-lucide="hand-coins" class="w-8 h-8 relative z-10 transition-transform group-hover:scale-110"></i>
        </div>
        <span class="font-bold text-gray-800">Financiación</span>
      </div>
    </div> <!-- Fin Grid de Iconos -->

  </div>
</div>
