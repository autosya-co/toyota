---
---

<nav class="bg-white shadow">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
    <!-- Logo -->
    <a href="/" class="hover:opacity-80 transition flex-shrink-0">
      <img src="https://lh3.googleusercontent.com/d/11WeKEM19rGyJQtjtyTFRDK_Y26QeYBSy" alt="Toyota Usados Logo" class="h-16 w-auto object-contain" />
    </a>

    <!-- Menú de Enlaces Clásicos -->
    <div class="flex flex-wrap justify-center items-center gap-3 md:gap-6 text-sm font-semibold text-gray-600 w-full md:w-auto mt-2 md:mt-0">
      <a href="/" class="hover:text-red-600 border-b-2 border-red-600 text-gray-900 transition-colors py-1">Inicio</a>
      <span class="text-gray-300 hidden sm:inline">|</span>
      <a href="#catalogoGrid" class="hover:text-red-600 transition-colors py-1">Inventario</a>
      <span class="text-gray-300 hidden sm:inline">|</span>
      <a href="#" class="hover:text-red-600 transition-colors py-1">Servicios</a>
      <span class="text-gray-300 hidden sm:inline">|</span>
      <a href="https://wa.me/573202832616" class="hover:text-red-600 transition-colors py-1">Contacto</a>
    </div>

    <!-- Botón Oculto/Admin subir vehículo -->
    <div class="hidden md:block admin-only-block" id="adminOptions">
      <div class="flex gap-2">
        <a href="/add" class="text-xs bg-gray-100 text-gray-400 hover:bg-red-50 hover:text-red-600 px-3 py-1.5 rounded transition font-medium">
          Subir Vehículo
        </a>
        <button onclick="if(window.logoutAdmin) window.logoutAdmin()" class="text-xs bg-gray-100 text-gray-400 hover:bg-gray-200 px-3 py-1.5 rounded transition font-medium">
          Salir
        </button>
      </div>
    </div>
    <script is:inline>
      window.logoutAdmin = function() {
        if (typeof localStorage !== 'undefined') {
          localStorage.removeItem('isAdmin');
          localStorage.removeItem('adminEmail');
          window.location.reload();
        }
      }
    </script>
  </div>
</nav>
