---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { db } from '../lib/firebase';
import { doc, getDoc } from 'firebase/firestore';

const configSnap = await getDoc(doc(db, "configuracion", "negocio"));
const urlAppsScriptServer = configSnap.exists() ? configSnap.data().url_apps_script : "";
---

<Layout title="Añadir Toyota | Toyota Usados">
  <script is:inline>
    // Proteger ruta: Exclusivo para usuarios logueados
    if (typeof localStorage !== 'undefined' && localStorage.getItem('isLoggedIn') !== 'true') {
      window.location.href = '/';
    }
  </script>
  <Navbar />
  
  <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-md p-8 border border-gray-200 shadow-sm mt-8 mb-8">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-gray-800">Publicar un Toyota</h1>
      <a href="/" class="text-sm text-red-600 hover:underline">← Volver al Catálogo</a>
    </div>

    <form id="formPublicar" class="space-y-6">
      <div>
        <label class="block text-sm font-semibold text-gray-700">Título del Anuncio</label>
        <input type="text" id="titulo" required placeholder="Ej: Toyota Hilux 2022 4x4" class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-600 focus:border-transparent">
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-semibold text-gray-700">Marca</label>
          <input type="text" disabled value="Toyota" class="mt-1 w-full px-4 py-2 border border-gray-300 bg-gray-100 rounded-lg text-gray-500 font-bold">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700">Modelo de Toyota</label>
          <select id="modelo" required class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-600 bg-white">
            <option value="">Cargando modelos...</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div><label class="block text-sm font-semibold text-gray-700">Año</label><input type="number" id="anio" required class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg"></div>
        <div><label class="block text-sm font-semibold text-gray-700">Precio (en pesos, sin puntos)</label><input type="number" id="precio" required class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg"></div>
        <div><label class="block text-sm font-semibold text-gray-700">Kilometraje</label><input type="number" id="kilometraje" required class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 bg-gray-50 p-4 rounded-lg border border-gray-200">
        <div>
          <label class="block text-xs font-semibold text-gray-700">Transmisión</label>
          <select id="transmision" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded">
            <option value="Mecánica">Mecánica</option>
            <option value="Automática">Automática</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700">Combustible</label>
          <select id="combustible" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded">
            <option value="Gasolina">Gasolina</option>
            <option value="Diesel">Diesel</option>
            <option value="Híbrido">Híbrido</option>
          </select>
        </div>
        <div><label class="block text-xs font-semibold text-gray-700">Motor</label><input type="number" id="motor" step="0.1" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded"></div>
        <div><label class="block text-xs font-semibold text-gray-700">Color</label><select id="color" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded"></select></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        <div><label class="block text-xs font-semibold text-gray-700">Último dígito placa</label><input type="number" id="digitoPlaca" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded"></div>
        <div class="col-span-2"><label class="block text-xs font-semibold text-gray-700">Ciudad de la Placa</label><input type="text" id="ciudadPlaca" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded"></div>
        <div>
          <label class="block text-xs font-semibold text-gray-700">Nacionalidad</label>
          <select id="nacionalidad" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded">
            <option value="Colombiano">Colombiano</option>
            <option value="Venezolano">Venezolano</option>
          </select>
        </div>
        <div><label class="block text-xs font-semibold text-gray-700">Tipo</label><select id="tipo" required class="mt-1 w-full px-3 py-2 text-sm border border-gray-300 rounded"></select></div>
      </div>
      
      <div><label class="block text-sm font-semibold text-gray-700">Nombre del Dueño (Interno)</label><input type="text" id="dueno" class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg"></div>

      <div>
        <label class="block text-sm font-semibold text-gray-700">Descripción / Equipamiento</label>
        <textarea id="contenido" rows="4" class="mt-1 w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-600 focus:border-transparent" placeholder="Describe el estado del vehículo, equipamiento extra, etc."></textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Imágenes (Se aplicará marca de agua)</label>
        <div id="dropzone" class="border-2 border-dashed border-red-400 bg-red-50 hover:bg-red-100 rounded-lg p-8 text-center cursor-pointer transition-colors relative">
          <p class="text-red-800 font-medium">Haz clic aquí o arrastra tus fotos</p>
          <input type="file" id="inputImagenesOculto" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
        </div>
        <div id="galeriaPrevia" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4 mt-4 min-h-[100px] p-4 bg-gray-50 border border-gray-200 rounded-lg empty:hidden"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200 mb-6 font-mono text-[10px] text-gray-400">
         <span>Apps Script: {urlAppsScriptServer ? 'CONECTADO' : 'PENDIENTE CONFIG'}</span>
      </div>

      <button type="submit" id="btnSubmit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-lg shadow flex justify-center items-center">
        <span id="btnText">Publicar Vehículo</span>
        <svg id="spinner" class="animate-spin ml-2 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
      </button>
      <div id="alerta" class="hidden p-4 rounded-lg text-center font-medium"></div>
    </form>
  </div>

  <script is:inline define:vars={{ urlAppsScriptServer }}>
    const URL_APPS_SCRIPT = urlAppsScriptServer || "https://script.google.com/macros/s/AKfycbzOu94N3mG5P7Z6jknzEnqtL1aDTKesxJ8jX2VgAdHw0doUeRdhr5X5O48COhhIcPy66g/exec";
    const URL_CSV_GOOGLE_SHEET = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQUXSBa4HqBFoaoXLVQW8Pvh7BRTfIhc3K8fz9wqBZHrE3DM1oo-A5v-5vsB74osUxNYOD5zEFA60vF/pub?gid=1038341741&single=true&output=csv";

    async function cargarDatosDinámicos() {
      // Usamos el Papa global que viene del Layout
      if (typeof Papa === 'undefined') {
        console.error("PapaParse no cargado aún. Reintentando...");
        setTimeout(cargarDatosDinámicos, 500);
        return;
      }

      Papa.parse(URL_CSV_GOOGLE_SHEET, {
        download: true, header: true, 
        complete: function(results) {
          const modelosToyota = new Set();
          const colores = new Set();
          const tipos = new Set();
          
          results.data.forEach(item => {
            if (item['Categorías'] && item['Categorías'].toLowerCase().startsWith('toyota')) {
              const partes = item['Categorías'].split('>');
              if (partes.length > 1) modelosToyota.add(partes[1].trim());
            }
            if (item['color_']) colores.add(item['color_'].trim());
            if (item['tipo']) tipos.add(item['tipo'].trim());
          });
          
          llenarSelect('modelo', Array.from(modelosToyota).sort(), 'Seleccione Modelo');
          llenarSelect('color', Array.from(colores).sort(), 'Seleccione Color');
          llenarSelect('tipo', Array.from(tipos).sort(), 'Seleccione Tipo');
        }
      });
    }

    function llenarSelect(id, array, textoDefault) {
      const el = document.getElementById(id);
      if (el) el.innerHTML = `<option value="">${textoDefault}</option>` + array.map(item => `<option value="${item}">${item}</option>`).join('');
    }

    // Ejecutar carga inicial
    cargarDatosDinámicos();

    let archivosAlmacenados = []; 
    const inputOculto = document.getElementById('inputImagenesOculto');
    const galeria = document.getElementById('galeriaPrevia');

    // Inicializar Sortable cuando esté disponible
    function initSortable() {
       if (typeof Sortable !== 'undefined' && galeria) {
          new Sortable(galeria, { animation: 150, onEnd: actualizarEtiquetaPortada });
       } else {
          setTimeout(initSortable, 500);
       }
    }
    initSortable();

    if (inputOculto) {
      inputOculto.addEventListener('change', function(e) {
        Array.from(e.target.files).forEach(file => {
          const idUnico = Math.random().toString(36).substr(2, 9);
          archivosAlmacenados.push({ id: idUnico, file: file });
          const reader = new FileReader();
          reader.onload = (ev) => {
            const divWrapper = document.createElement('div');
            divWrapper.className = 'relative group cursor-move aspect-video bg-gray-200 rounded overflow-hidden shadow';
            divWrapper.setAttribute('data-id', idUnico);
            divWrapper.innerHTML = `
              <img src="${ev.target.result}" class="object-cover w-full h-full pointer-events-none">
              <button type="button" onclick="eliminarImagen('${idUnico}', this)" class="absolute top-1 right-1 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs hover:bg-red-600">✕</button>
              <div class="etiqueta-portada hidden absolute bottom-0 left-0 right-0 bg-red-600 text-white text-[10px] text-center py-0.5 font-bold">PORTADA</div>
            `;
            galeria.appendChild(divWrapper);
            actualizarEtiquetaPortada();
          };
          reader.readAsDataURL(file);
        });
        this.value = ""; 
      });
    }

    window.eliminarImagen = function(id, btnElement) {
      archivosAlmacenados = archivosAlmacenados.filter(item => item.id !== id);
      btnElement.parentElement.remove(); 
      actualizarEtiquetaPortada();
    }

    function actualizarEtiquetaPortada() {
      if (!galeria) return;
      const items = galeria.children;
      for(let i=0; i<items.length; i++){
        const etiqueta = items[i].querySelector('.etiqueta-portada');
        if (etiqueta) {
           if(i === 0) etiqueta.classList.remove('hidden'); else etiqueta.classList.add('hidden');
        }
      }
    }

    const convertirABase64 = (fileObj) => {
      return new Promise((resolve) => {
        const reader = new FileReader();
        reader.onload = (e) => resolve({ 
          base64: e.target.result, 
          nombre: fileObj.file.name, 
          tipo: fileObj.file.type 
        });
        reader.readAsDataURL(fileObj.file);
      });
    };

    const formPublicar = document.getElementById('formPublicar');
    if (formPublicar) {
      formPublicar.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btnSubmit'); 
        const spinner = document.getElementById('spinner'); 
        const alerta = document.getElementById('alerta');

        const elementosDOMOrdenados = Array.from(galeria.children);
        const archivosOrdenados = elementosDOMOrdenados.map(el => archivosAlmacenados.find(item => item.id === el.getAttribute('data-id'))).filter(Boolean);

        if(archivosOrdenados.length === 0) { alert("Sube al menos una foto"); return; }
        btn.disabled = true; btn.classList.add('opacity-75'); spinner.classList.remove('hidden'); alerta.classList.add('hidden');

        try {
          const archivosBase64 = await Promise.all(archivosOrdenados.map(obj => convertirABase64(obj)));
          
          const payload = {
            titulo: document.getElementById('titulo').value,
            categoriaUnida: "Toyota>" + document.getElementById('modelo').value,
            anio: document.getElementById('anio').value, 
            precio: document.getElementById('precio').value, 
            kilometraje: document.getElementById('kilometraje').value,
            transmision: document.getElementById('transmision').value, 
            combustible: document.getElementById('combustible').value, 
            motor: document.getElementById('motor').value, 
            color: document.getElementById('color').value,
            digitoPlaca: document.getElementById('digitoPlaca').value, 
            ciudadPlaca: document.getElementById('ciudadPlaca').value, 
            nacionalidad: document.getElementById('nacionalidad').value, 
            tipo: document.getElementById('tipo').value,
            dueno: document.getElementById('dueno').value, 
            contenido: document.getElementById('contenido').value,
            archivos: archivosBase64,
            usuario: localStorage.getItem('userEmail') || "usuario_desconocido"
          };

          const respuesta = await fetch(URL_APPS_SCRIPT, { method: 'POST', body: JSON.stringify(payload) });
          const resultado = await respuesta.json();

          alerta.classList.remove('hidden', 'bg-red-100', 'text-red-800');
          if (resultado.exito) {
            alerta.classList.add('bg-green-100', 'text-green-800'); 
            alerta.innerText = "¡Publicado con éxito! Redireccionando...";
            formPublicar.reset(); galeria.innerHTML = ""; archivosAlmacenados = []; 
            setTimeout(() => {
              window.location.href = `/${resultado.id}/${resultado.slug}`;
            }, 1500);
          } else throw new Error(resultado.mensaje);

        } catch (error) {
          alerta.classList.remove('hidden', 'bg-green-100', 'text-green-800'); alerta.classList.add('bg-red-100', 'text-red-800'); alerta.innerText = "Error: " + error.message;
        } finally {
          btn.disabled = false; btn.classList.remove('opacity-75'); spinner.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>
