---
export const prerender = false; // SSR: no pre-renderizar, generar en el servidor

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { db } from '../../lib/firebase';
import { collection, query, where, getDocs } from 'firebase/firestore';

const { id } = Astro.params;

let carro: any = null;
try {
  let paramId = id;
  // Búsqueda del ID como String
  let q = query(collection(db, "toyotausados"), where("ID", "==", String(paramId).trim()));
  let snapshot = await getDocs(q);
  
  // Respaldo en caso de que esté guardado como Número
  if (snapshot.empty && !isNaN(Number(paramId))) {
    q = query(collection(db, "toyotausados"), where("ID", "==", Number(paramId)));
    snapshot = await getDocs(q);
  }
  
  if (!snapshot.empty) {
    carro = snapshot.docs[0].data();
  }
} catch (e) {
  console.error("Error obteniendo vehiculo desde Firebase:", e);
}

// Si no se encuentra el vehículo → 404
if (!carro) {
  return Astro.redirect('/404');
}

const formatearDinero = (cantidad: any) =>
  new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(Number(cantidad) || 0);
const formatearKm = (km: any) =>
  km ? new Intl.NumberFormat('es-CO').format(Number(km)) + ' km' : '0 km';

let idsDrive: string[] = [];
if (carro.Images) {
  idsDrive = carro.Images.split('|').map((id: string) => id.trim()).filter((id: string) => id !== '');
}

const mensaje = encodeURIComponent(`Hola, estoy interesado en el vehículo *${carro.Title}* que vi en toyotausados.com.`);
const urlWhatsapp = 'https://wa.me/573202832616?text=' + mensaje;
const anio = carro.a_o || '-';
const totalImagenes = idsDrive.length;
const descripcionMeta = `${carro.Title} — ${anio}, ${formatearKm(carro.Mileage)}, ${carro.Transmission || ''} ${carro['Fuel'] || ''}. Precio: ${formatearDinero(carro.Price)}. Toyota Usados Colombia.`;
---

<Layout title={`${carro.Title} | Toyota Usados`}>
  <Fragment slot="head">
    <meta name="description" content={descripcionMeta} />
    <meta property="og:title" content={`${carro.Title} | Toyota Usados`} />
    <meta property="og:description" content={descripcionMeta} />
    {idsDrive[0] && <meta property="og:image" content={`https://drive.google.com/thumbnail?id=${idsDrive[0]}&sz=w1200`} />}
    <meta property="og:type" content="product" />
  </Fragment>

  <Navbar />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">

      <!-- Cabecera -->
      <div class="px-6 py-5 border-b border-gray-100 bg-gray-50">
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900">{carro.Title}</h1>
      </div>

      <!-- Cuerpo: 2 columnas en desktop -->
      <div class="p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">

          <!-- ─── Columna Izquierda: Carrusel ─── -->
          <div>
            {totalImagenes > 0 ? (
              <div class="space-y-4">
                <!-- Main Image -->
                <div class="relative bg-gray-900 rounded-xl overflow-hidden cursor-pointer group shadow-2xl" 
                     style="aspect-ratio: 4/3;" 
                     id="openLightbox">
                  
                  <div id="carouselTrack"
                    class="flex h-full transition-transform duration-500 ease-in-out">
                    {idsDrive.map((driveId, i) => (
                      <div class="w-full h-full flex-shrink-0 flex items-center justify-center bg-gray-900/50"
                        style="min-width: 100%;">
                        <img
                          src={`https://drive.google.com/thumbnail?id=${driveId}&sz=w1200`}
                          alt={carro.Title}
                          class="max-w-full max-h-full w-auto h-auto object-contain select-none transition-transform duration-700 group-hover:scale-105"
                          referrerpolicy="no-referrer"
                          loading={i === 0 ? 'eager' : 'lazy'}
                        />
                      </div>
                    ))}
                  </div>

                  {totalImagenes > 1 && (
                    <>
                      <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-black/20 to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
                      <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-black/20 to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
                      
                      <button id="prevBtn" aria-label="Anterior"
                        class="absolute left-3 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white w-12 h-12 rounded-full flex items-center justify-center transition-all z-10 backdrop-blur-md opacity-0 group-hover:opacity-100 border border-white/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                      </button>
                      <button id="nextBtn" aria-label="Siguiente"
                        class="absolute right-3 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white w-12 h-12 rounded-full flex items-center justify-center transition-all z-10 backdrop-blur-md opacity-0 group-hover:opacity-100 border border-white/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                      </button>
                    </>
                  )}

                  <div class="absolute bottom-4 right-4 bg-black/60 text-white text-[11px] px-3 py-1.5 rounded-lg z-10 backdrop-blur-xl border border-white/10 font-bold tracking-widest shadow-lg">
                    <span id="currentImg" class="text-red-400">1</span> / {totalImagenes}
                  </div>
                  
                  <!-- Fullscreen Hint -->
                  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none">
                    <div class="bg-white/20 backdrop-blur-md p-3 rounded-full border border-white/30">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                      </svg>
                    </div>
                  </div>
                </div>

                <!-- Miniaturas -->
                {totalImagenes > 1 && (
                  <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-transparent snap-x">
                    {idsDrive.map((driveId, i) => (
                      <button 
                        class={`thumb-btn flex-shrink-0 w-20 md:w-24 aspect-video rounded-lg overflow-hidden border-2 transition-all snap-start ${i === 0 ? 'border-red-600 scale-95 shadow-md' : 'border-transparent opacity-60 hover:opacity-100'}`}
                        data-index={i}
                      >
                        <img 
                          src={`https://drive.google.com/thumbnail?id=${driveId}&sz=w300`} 
                          class="w-full h-full object-cover" 
                          alt={`Miniatura ${i + 1}`}
                          loading="lazy"
                        />
                      </button>
                    ))}
                  </div>
                )}
              </div>
            ) : (
              <div class="aspect-[4/3] bg-gray-100 rounded-xl flex items-center justify-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            )}
          </div>

          <!-- ─── Columna Derecha: Información ─── -->
          <div class="flex flex-col h-full">
            <div class="text-4xl font-extrabold text-red-700 mb-6">
              {formatearDinero(carro.Price)}
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Año</span>
                <span class="font-bold text-gray-800 text-base">{anio}</span>
              </div>
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Kilometraje</span>
                <span class="font-bold text-gray-800 text-base">{formatearKm(carro.Mileage)}</span>
              </div>
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Transmisión</span>
                <span class="font-bold text-gray-800 text-base">{carro.Transmission || carro.transmision || '-'}</span>
              </div>
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Combustible</span>
                <span class="font-bold text-gray-800 text-base">{carro.Fuel || carro.combustible || '-'}</span>
              </div>
            </div>

            <h4 class="font-bold text-gray-900 border-b-2 border-gray-200 pb-2 mb-3 uppercase text-xs tracking-wider">
              Más Especificaciones
            </h4>
            <ul class="text-sm text-gray-700 space-y-2 mb-6">
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Motor:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded">{carro.Engine || '-'}</span>
              </li>
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Color:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded">{carro.color_ || '-'}</span>
              </li>
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Placa termina en:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded">
                  {(carro.Plate_last_digit !== undefined && carro.Plate_last_digit !== null) ? carro.Plate_last_digit : '-'}
                </span>
              </li>
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Ciudad placa:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded capitalize">{carro.ciudad_de_la_placa || '-'}</span>
              </li>
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Nacionalidad:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded capitalize">{carro.nac || '-'}</span>
              </li>
              <li class="flex justify-between items-center">
                <span class="font-medium text-gray-500">Tipo:</span>
                <span class="font-bold bg-gray-100 px-3 py-0.5 rounded capitalize">{carro.tipo || '-'}</span>
              </li>
            </ul>

            <h4 class="font-bold text-gray-900 border-b-2 border-gray-200 pb-2 mb-3 uppercase text-xs tracking-wider">
              Descripción del Vendedor
            </h4>
            <div class="text-sm text-gray-800 whitespace-pre-wrap leading-relaxed bg-red-50/50 p-4 rounded-xl border border-red-100 italic flex-grow mb-6">
              {carro.Content || 'Sin descripción adicional.'}
            </div>

            <a
              href={urlWhatsapp}
              target="_blank"
              class="mt-auto bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-xl transition-all flex items-center justify-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-1 w-full text-lg">
              💬 Contactar Vendedor
            </a>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ─── Lightbox Modal (Fullscreen) ─── -->
  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-lg hidden flex-col transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="flex justify-between items-center px-6 py-4">
      <div class="text-white font-bold text-sm md:text-lg truncate max-w-[70%]">
        {carro.Title}
      </div>
      <button id="closeLightbox" class="text-white/70 hover:text-white transition p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <div class="flex-grow relative flex items-center justify-center overflow-hidden">
       <!-- Navigation Buttons (Lightbox) -->
       <button id="lbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white w-12 h-12 rounded-full flex items-center justify-center transition z-[110] backdrop-blur-md border border-white/10">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
       </button>
       <button id="lbNext" class="absolute right-4 top-1/2 -translate-y-1/2 bg-white/10 hover:bg-white/20 text-white w-12 h-12 rounded-full flex items-center justify-center transition z-[110] backdrop-blur-md border border-white/10">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
       </button>

       <div id="lbTrack" class="flex h-full transition-transform duration-300 ease-out" style="width: 100%;">
         {idsDrive.map((driveId) => (
           <div class="flex-shrink-0 flex items-center justify-center" style="min-width: 100%; height: 100%;">
             <img
               src={`https://drive.google.com/thumbnail?id=${driveId}&sz=w1600`}
               class="max-w-full max-h-full object-contain"
               referrerpolicy="no-referrer"
             />
           </div>
         ))}
       </div>
    </div>

    <div class="py-6 flex flex-col items-center gap-2">
      <div class="text-white/50 text-xs font-mono tracking-tighter uppercase">
        Imagen <span id="lbCurrent">1</span> de {totalImagenes}
      </div>
      <div class="flex gap-1.5 overflow-x-auto max-w-[90vw] px-4 no-scrollbar">
         {idsDrive.map((_, i) => (
            <div data-lb-index={i} class={`lb-dot w-1.5 h-1.5 rounded-full transition-all ${i === 0 ? 'bg-red-500 w-4' : 'bg-white/20'}`}></div>
         ))}
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ totalImagenes }}>
    if (totalImagenes > 0) {
      let current = 0;
      const track = document.getElementById('carouselTrack');
      const counter = document.getElementById('currentImg');
      const thumbBtns = document.querySelectorAll('.thumb-btn');
      
      // Lightbox elements
      const lightbox = document.getElementById('lightbox');
      const lbTrack = document.getElementById('lbTrack');
      const lbCounter = document.getElementById('lbCurrent');
      const lbDots = document.querySelectorAll('.lb-dot');
      const openLbBtn = document.getElementById('openLightbox');
      const closeLbBtn = document.getElementById('closeLightbox');

      function updateGallery(index) {
        current = (index + totalImagenes) % totalImagenes;
        
        // Carrusel Principal
        if (track) track.style.transform = `translateX(-${current * 100}%)`;
        if (counter) counter.textContent = current + 1;
        
        // Miniaturas
        thumbBtns.forEach((btn, i) => {
          if (i === current) {
            btn.classList.add('border-red-600', 'scale-95', 'shadow-md');
            btn.classList.remove('border-transparent', 'opacity-60');
          } else {
            btn.classList.remove('border-red-600', 'scale-95', 'shadow-md');
            btn.classList.add('border-transparent', 'opacity-60');
          }
        });

        // Lightbox
        if (lbTrack) lbTrack.style.transform = `translateX(-${current * 100}%)`;
        if (lbCounter) lbCounter.textContent = current + 1;
        lbDots.forEach((dot, i) => {
          if (i === current) {
            dot.classList.add('bg-red-500', 'w-4');
            dot.classList.remove('bg-white/20');
          } else {
            dot.classList.remove('bg-red-500', 'w-4');
            dot.classList.add('bg-white/20');
          }
        });
      }

      // Event Listeners
      document.getElementById('prevBtn')?.addEventListener('click', (e) => { e.stopPropagation(); updateGallery(current - 1); });
      document.getElementById('nextBtn')?.addEventListener('click', (e) => { e.stopPropagation(); updateGallery(current + 1); });
      thumbBtns.forEach((btn, i) => btn.addEventListener('click', () => updateGallery(i)));

      // Lightbox controls
      openLbBtn?.addEventListener('click', () => {
        lightbox.classList.remove('hidden', 'pointer-events-none');
        setTimeout(() => lightbox.classList.remove('opacity-0'), 10);
        document.body.style.overflow = 'hidden'; // Bloquear scroll
        updateGallery(current);
      });

      const closeAction = () => {
        lightbox.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
        setTimeout(() => lightbox.classList.add('hidden'), 300);
      };

      closeLbBtn?.addEventListener('click', closeAction);
      document.getElementById('lbPrev')?.addEventListener('click', () => updateGallery(current - 1));
      document.getElementById('lbNext')?.addEventListener('click', () => updateGallery(current + 1));

      // Close on escape
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAction(); });

      // Swipe support (Mobile)
      let touchX = 0;
      const addSwipe = (el) => {
        el?.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
        el?.addEventListener('touchend', e => {
          const diff = touchX - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 50) updateGallery(diff > 0 ? current + 1 : current - 1);
        });
      };
      addSwipe(track);
      addSwipe(lbTrack);

      // Auto-play opcional (solo si no se ha interactuado)
      let interval = setInterval(() => updateGallery(current + 1), 7000);
      const stopInterval = () => { if(interval) { clearInterval(interval); interval = null; } };
      
      [track, lbTrack, ...thumbBtns].forEach(el => el?.addEventListener('click', stopInterval, {once: true}));
    }
  </script>
</Layout>
