---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Papa from 'papaparse';

export async function getStaticPaths() {
  const URL_CSV = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQUXSBa4HqBFoaoXLVQW8Pvh7BRTfIhc3K8fz9wqBZHrE3DM1oo-A5v-5vsB74osUxNYOD5zEFA60vF/pub?gid=1038341741&single=true&output=csv";
  
  const response = await fetch(URL_CSV);
  const csvText = await response.text();
  
  const results = Papa.parse(csvText, { header: true });
  const inventario = results.data.filter((c: any) => c.ID && c.Title);

  const slugify = (text: string) => {
    return text.toString().toLowerCase()
      .trim()
      .normalize('NFD') // separa acentos
      .replace(/[\u0300-\u036f]/g, "") // borra acentos
      .replace(/\s+/g, '-')           // Replace spaces con -
      .replace(/[^\w\-]+/g, '')       // Elimina chars raros
      .replace(/\-\-+/g, '-');        // Dobles - a simples
  };

  return inventario.map((carro: any) => {
    return {
      params: { 
        id: carro.ID.toString(),
        titulo: slugify(carro.Title) 
      },
      props: { carro },
    };
  });
}

const { carro } = Astro.props;

// Funciones de formateo 
const formatearDinero = (cantidad: any) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(Number(cantidad) || 0);
const formatearKm = (km: any) => km ? new Intl.NumberFormat('es-CO').format(Number(km)) + ' km' : '0 km';

// Extraer imágenes
let idsDrive: string[] = [];
if (carro.Images) {
  idsDrive = carro.Images.split('|').map((id: string) => id.trim()).filter((id: string) => id !== '');
}
const urlImagenPrincipal = idsDrive.length > 0 ? `https://drive.google.com/thumbnail?id=${idsDrive[0]}&sz=w800` : 'https://via.placeholder.com/800x600?text=Sin+Imagen';

// Botón de WhatsApp
let telefono = carro.dueno ? carro.dueno.toString().replace(/[^0-9\+]/g, '') : '';
if (telefono && !telefono.startsWith('+') && telefono.length === 10) telefono = '+57' + telefono;
const mensaje = encodeURIComponent(`Hola, estoy interesado en el vehículo *${carro.Title}* que vi en toyotausados.com.`);
// Establecemos el teléfono duro como se solicitó para toyotausados.com
const urlWhatsapp = 'https://wa.me/573202832616?text=' + mensaje;
const anio = carro.a_o || '-';
---

<Layout title={`${carro.Title} | Toyota Usados`}>
  <Navbar />
  
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <!-- Botón volver -->
    <a href="/" class="inline-flex items-center text-red-600 hover:text-red-800 font-medium mb-6 transition group">
      <i data-lucide="arrow-left" class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition"></i>
      Volver al catálogo
    </a>

    <!-- Page Content -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col transform">
      <!-- Cabecera -->
      <div class="px-6 py-5 border-b border-gray-100 bg-gray-50">
        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 pr-4">{carro.Title}</h1>
      </div>

      <!-- Cuerpo -->
      <div class="p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          
          <!-- Columna Izquierda: Galería -->
          <div>
            <div class="relative aspect-[4/3] bg-gray-100 rounded-xl overflow-hidden mb-4 border border-gray-200 shadow-inner">
              <img
                id="imagenPrincipalPage"
                src={urlImagenPrincipal}
                alt={`Foto principal de ${carro.Title}`}
                class="w-full h-full object-contain bg-gray-50"
                referrerpolicy="no-referrer"
              />
            </div>
            
            <!-- Miniaturas -->
            {idsDrive.length > 0 && (
              <div class="flex gap-3 py-2 overflow-x-auto pb-4 custom-scrollbar">
                {idsDrive.map((id) => (
                  <button
                    type="button"
                    class="miniatura-btn flex-shrink-0 w-24 h-16 md:w-28 md:h-20 rounded-md overflow-hidden ring-2 ring-transparent hover:ring-red-500 focus:outline-none focus:ring-red-500 transition shadow-sm opacity-80 hover:opacity-100"
                    data-urlMax={`https://drive.google.com/thumbnail?id=${id}&sz=w800`}
                  >
                    <img src={`https://drive.google.com/thumbnail?id=${id}&sz=w200`} class="w-full h-full object-cover" alt="Miniatura" referrerpolicy="no-referrer" />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Columna Derecha: Información -->
          <div class="flex flex-col h-full">
            <div class="text-4xl font-extrabold text-red-700 mb-8">
              {formatearDinero(carro.Price)}
            </div>

            <div class="grid grid-cols-2 gap-4 mb-8">
              <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Año</span>
                <span class="font-bold text-gray-800 flex items-center gap-2 text-lg">
                  <i data-lucide="calendar" class="w-5 h-5 text-red-600"></i> {anio}
                </span>
              </div>
              <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Kilometraje</span>
                <span class="font-bold text-gray-800 flex items-center gap-2 text-lg">
                  <i data-lucide="gauge" class="w-5 h-5 text-red-600"></i> {formatearKm(carro.Mileage)}
                </span>
              </div>
              <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Transmisión</span>
                <span class="font-bold text-gray-800 flex items-center gap-2 text-lg">
                  <i data-lucide="settings-2" class="w-5 h-5 text-red-600"></i> {carro.Transmission || '-'}
                </span>
              </div>
              <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 shadow-sm">
                <span class="text-xs text-gray-500 font-bold uppercase block mb-1 tracking-wider">Combustible</span>
                <span class="font-bold text-gray-800 flex items-center gap-2 text-lg">
                  <i data-lucide="fuel" class="w-5 h-5 text-red-600"></i> {carro['Fuel '] || carro['Fuel'] || '-'}
                </span>
              </div>
            </div>

            <h4 class="font-bold text-gray-900 border-b-2 border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider">
              Más Especificaciones
            </h4>
            <ul class="text-sm md:text-base text-gray-700 space-y-3 mb-8">
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Motor:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded">{carro.Engine || '-'}</span></li>
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Color:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded">{carro.color_ || '-'}</span></li>
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Placa terminada en:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded">{(carro.Plate_last_digit !== undefined && carro.Plate_last_digit !== null) ? carro.Plate_last_digit : '-'}</span></li>
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Ciudad placa:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded capitalize">{carro.ciudad_de_la_placa || '-'}</span></li>
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Nacionalidad:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded capitalize">{carro.nac || '-'}</span></li>
              <li class="flex justify-between items-center"><span class="font-medium text-gray-500">Tipo:</span> <span class="font-bold bg-gray-100 px-3 py-1 rounded capitalize">{carro.tipo || '-'}</span></li>
            </ul>

            <h4 class="font-bold text-gray-900 border-b-2 border-gray-200 pb-2 mb-4 uppercase text-sm tracking-wider mt-auto">
              Descripción del Vendedor
            </h4>
            <div class="text-sm md:text-base text-gray-800 whitespace-pre-wrap leading-relaxed bg-red-50/50 p-5 rounded-xl border border-red-100 italic">
              {carro.Content || 'Sin descripción adicional.'}
            </div>
            
            <div class="mt-8">
              {telefono ? (
                <a
                  href={urlWhatsapp}
                  target="_blank"
                  class="bg-green-600 hover:bg-green-700 text-white font-bold py-4 px-6 rounded-xl transition-all flex items-center justify-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-1 w-full text-lg"
                >
                  <i data-lucide="message-circle" class="w-6 h-6"></i> Contactar Vendedor
                </a>
              ) : (
                <div class="bg-gray-200 text-center py-4 px-6 rounded-xl text-gray-500 font-bold">
                  No hay número de contacto
                </div>
              )}
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Script cliente para cambiar foto principal al hacer clic en miniaturas
    document.addEventListener("DOMContentLoaded", () => {
      const imgPrincipal = document.getElementById("imagenPrincipalPage");
      const botones = document.querySelectorAll(".miniatura-btn");
      
      botones.forEach(btn => {
        btn.addEventListener("click", () => {
          const urlMax = btn.getAttribute("data-urlMax");
          if (urlMax && imgPrincipal) {
            imgPrincipal.src = urlMax;
          }
        });
      });
    });
  </script>
</Layout>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    height: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #f1f1f1; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #cbd5e1; 
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #94a3b8; 
  }
</style>
